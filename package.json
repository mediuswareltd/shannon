{
  "name": "shannon",
  "version": "0.0.1",
  "private": true,
  "description": "Shannon — monitor board for GitHub and more",
  "homepage": "https://github.com/mediuswareltd/PE-board-monitor",
  "repository": {
    "type": "git",
    "url": "https://github.com/mediuswareltd/PE-board-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/mediuswareltd/PE-board-monitor/issues"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm version patch --no-git-tag-version -f && electron-vite build && electron-builder",
    "dist:ci": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.shannon.peboard",
    "productName": "Shannon",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mediuswareltd",
        "repo": "PE-board-monitor"
      }
    ]
  }
}
